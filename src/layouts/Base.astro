---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  publishedAt?: string;
  updatedAt?: string;
  articleBody?: string;
  articleCategory?: string;
  articleSlug?: string;
  articleType?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  noindex = false,
  publishedAt,
  updatedAt,
  articleBody,
  articleCategory,
  articleSlug,
  articleType = false,
} = Astro.props;

const siteUrl = 'https://insights.covecollect.com';
const canonical = canonicalUrl || Astro.url.href;
const defaultOgImage = `${siteUrl}/og-default.jpg`;

// Trim article body for JSON-LD — rich results benefit from some body text,
// but we don't want the full 3000-word article in head.
const articleBodyForSchema = articleBody
  ? articleBody.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 1200)
  : undefined;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:image" content={ogImage || defaultOgImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Cove Insights" />
  <meta property="og:type" content={articleType ? 'article' : 'website'} />
  {publishedAt && <meta property="article:published_time" content={publishedAt} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage || defaultOgImage} />

  <!-- Schema.org: Article (detail pages only) -->
  {articleType && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "image": ogImage || defaultOgImage,
      "datePublished": publishedAt,
      ...(updatedAt ? { "dateModified": updatedAt } : {}),
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
      "author": {
        "@type": "Organization",
        "name": "Cove Editorial",
        "url": "https://covecollect.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Cove",
        "url": "https://covecollect.com",
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/cove-logo.png`
        }
      },
      ...(articleBodyForSchema ? { "articleBody": articleBodyForSchema } : {}),
      ...(articleCategory ? { "articleSection": articleCategory } : {})
    })} />
  )}

  <!-- Schema.org: BreadcrumbList (detail pages) — renders breadcrumbs in SERP -->
  {articleType && articleSlug && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Insights", "item": siteUrl },
        ...(articleCategory ? [{
          "@type": "ListItem", "position": 2,
          "name": articleCategory.charAt(0).toUpperCase() + articleCategory.slice(1),
          "item": `${siteUrl}/?category=${articleCategory}`
        }] : []),
        {
          "@type": "ListItem",
          "position": articleCategory ? 3 : 2,
          "name": title,
          "item": `${siteUrl}/${articleSlug}`
        }
      ]
    })} />
  )}

  <!-- Schema.org: WebSite + Organization (every page) — feeds sitelinks search box
       and general brand signals. -->
  {!articleType && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Cove Insights",
      "url": siteUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Cove",
        "url": "https://covecollect.com",
        "logo": { "@type": "ImageObject", "url": `${siteUrl}/cove-logo.png` }
      }
    })} />
  )}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-CVBXNJGD79"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CVBXNJGD79', {
      linker: {
        domains: ['covecollect.com', 'insights.covecollect.com']
      }
    });
  </script>

  <style is:global>
    :root {
      /* Aligned with covecollect.com palette — cove-950 / cove-warm from the
         main site's Tailwind config so insights.covecollect.com feels
         like a continuation of the product site. */
      --bg: #09090b;
      --bg-elevated: #131316;
      --bg-subtle: #1a1a1f;
      --text-primary: #F5F4F0;
      --text-secondary: #9B9B8E;
      --text-tertiary: #5C5C52;
      --gold: #c9a86c;
      --gold-hover: #d4b87d;
      --gold-muted: #8b7355;
      --gold-subtle: rgba(201, 168, 108, 0.12);
      --border: rgba(245, 244, 240, 0.06);
      --border-strong: rgba(245, 244, 240, 0.12);
      /* Match covecollect.com — Plus Jakarta Sans is the site-wide face.
         Cormorant Garamond is retained for occasional editorial serif moments. */
      --font-display: 'Plus Jakarta Sans', system-ui, sans-serif;
      --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
      --font-serif: 'Cormorant Garamond', Georgia, serif;
      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 24px;
      --space-xl: 48px;
      --space-2xl: 80px;
      --space-3xl: 120px;
      --max-content: 1280px;
      --max-article: 680px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a { color: inherit; text-decoration: none; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <!-- NAV — mirrors covecollect.com PublicShell header for cross-site parity -->
  <header class="site-header" id="site-header">
    <div class="site-header-inner">
      <a href="https://covecollect.com" class="site-header-logo" aria-label="Cove Collect home">
        <img src="/cove-wordmark-white.png" alt="Cove Collect" />
      </a>

      <nav class="site-header-nav" aria-label="Primary">
        <a href="https://covecollect.com/#what-is-cove" class="nav-link" onclick="window.gtag?.('event', 'platform_nav_clicked', { source: 'insights_blog' })">The Platform</a>
        <a href="/" class="nav-link" aria-current="page">Insights</a>
        <a href="https://covecollect.com/login" class="nav-link" onclick="window.gtag?.('event', 'login_clicked', { source: 'insights_nav' })">Log In</a>
        <a href="https://covecollect.com/request-access" class="nav-cta" onclick="window.gtag?.('event', 'request_access_clicked', { source: 'insights_nav' })">Request Access</a>
      </nav>

      <button class="site-header-hamburger" id="site-header-hamburger" aria-label="Toggle menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>

    <div class="site-header-mobile" id="site-header-mobile" hidden>
      <a href="https://covecollect.com/#what-is-cove" class="mobile-link">The Platform</a>
      <a href="/" class="mobile-link">Insights</a>
      <a href="https://covecollect.com/login" class="mobile-link">Log In</a>
      <a href="https://covecollect.com/request-access" class="mobile-cta">Request Access</a>
    </div>
  </header>

  <script is:inline>
    // Transparent-at-top → opaque-with-blur on scroll, matching PublicShell behavior.
    (function () {
      const header = document.getElementById('site-header');
      if (!header) return;
      const onScroll = () => {
        if (window.scrollY > 50) header.classList.add('site-header--scrolled');
        else header.classList.remove('site-header--scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      const toggle = document.getElementById('site-header-hamburger');
      const mobile = document.getElementById('site-header-mobile');
      if (toggle && mobile) {
        toggle.addEventListener('click', () => {
          const isOpen = !mobile.hasAttribute('hidden');
          if (isOpen) {
            mobile.setAttribute('hidden', '');
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            mobile.removeAttribute('hidden');
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      }
    })();
  </script>

  <slot />

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-wordmark">cove</span>
        <p class="footer-tagline">For collectors who think in decades.</p>
      </div>
      <div class="footer-right">
        <p class="footer-copyright">&copy; {new Date().getFullYear()} Cove Collect</p>
        <div class="footer-links">
          <a href="https://covecollect.com">covecollect.com</a>
          <a href="https://covecollect.com">Appraisals</a>
          <a href="https://covecollect.com">Insurance</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ──────────────────────────────────────────────────────────────────────
     Header — structural parity with covecollect.com PublicShell.
     Transparent at top; opaque + blur after 50px scroll.
     Fixed, not sticky — matches main site's behavior over the hero area.
     ────────────────────────────────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 300ms ease, backdrop-filter 300ms ease, border-color 300ms ease;
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  .site-header--scrolled {
    background: rgba(9, 9, 11, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  .site-header-inner {
    max-width: var(--max-content);
    margin: 0 auto;
    min-height: 72px;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .site-header-logo img {
    height: 32px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 767px) {
    .site-header-logo img { height: 28px; }
  }

  .site-header-nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  @media (max-width: 767px) {
    .site-header-nav { display: none; }
  }

  .nav-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 200ms;
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: #fff;
  }

  .nav-cta {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    background: var(--gold);
    color: #09090b;
    padding: 10px 20px;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms;
  }

  .nav-cta:hover {
    background: var(--gold-hover);
  }

  .site-header-hamburger {
    display: none;
    background: transparent;
    border: 0;
    padding: 8px;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
  }

  .site-header-hamburger:hover { color: #fff; }

  @media (max-width: 767px) {
    .site-header-hamburger { display: inline-flex; }
  }

  /* Hidden by default — CSS display wins over the HTML `hidden` attribute
     when a non-none display is set. Only reveal on mobile viewport when
     the script removes the [hidden] attribute. */
  .site-header-mobile {
    display: none;
    padding: 8px 24px 20px;
    flex-direction: column;
    gap: 4px;
    background: rgba(9, 9, 11, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 767px) {
    .site-header-mobile:not([hidden]) {
      display: flex;
    }
  }

  .mobile-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.7);
    padding: 12px 0;
    text-decoration: none;
  }

  .mobile-link:hover { color: #fff; }

  .mobile-cta {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    background: var(--gold);
    color: #09090b;
    padding: 12px 24px;
    border-radius: 9999px;
    text-decoration: none;
    text-align: center;
    margin-top: 8px;
  }

  .mobile-cta:hover { background: var(--gold-hover); }

  /* Push page content below the fixed header */
  body { padding-top: 72px; }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 60px 2rem 40px;
    margin-top: 0;
  }

  .footer-inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--text-primary);
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 8px;
  }

  .footer-right {
    text-align: right;
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .footer-links {
    display: flex;
    gap: 16px;
    margin-top: 8px;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-tertiary);
    transition: color 150ms;
  }

  .footer-links a:hover {
    color: var(--gold);
  }

  @media (max-width: 640px) {
    .site-nav {
      padding: 0 1rem;
    }

    .nav-links {
      display: none;
    }

    .nav-link-mobile {
      display: block;
    }

    .footer-inner {
      flex-direction: column;
      gap: 24px;
    }

    .footer-right {
      text-align: left;
    }
  }
</style>
