---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  publishedAt?: string;
  articleType?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  noindex = false,
  publishedAt,
  articleType = false,
} = Astro.props;

const siteUrl = 'https://insights.covecollect.com';
const canonical = canonicalUrl || Astro.url.href;
const defaultOgImage = `${siteUrl}/og-default.jpg`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:image" content={ogImage || defaultOgImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Cove Insights" />
  <meta property="og:type" content={articleType ? 'article' : 'website'} />
  {publishedAt && <meta property="article:published_time" content={publishedAt} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage || defaultOgImage} />

  <!-- Schema.org structured data for articles -->
  {articleType && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "image": ogImage || defaultOgImage,
      "datePublished": publishedAt,
      "publisher": {
        "@type": "Organization",
        "name": "Cove",
        "url": "https://covecollect.com",
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/cove-logo.png`
        }
      }
    })} />
  )}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CVBXNJGD79"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CVBXNJGD79');
  </script>

  <style is:global>
    :root {
      --gold: #C4A55A;
      --text-primary: #1A1A1A;
      --text-secondary: #6B7280;
      --border: #E5E7EB;
      --bg: #FAFAF8;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav style="border-bottom: 1px solid var(--border); padding: 0 2rem; height: 56px; display: flex; align-items: center; justify-content: space-between; background: white;">
    <a href="https://covecollect.com" style="display: flex; align-items: center; gap: 8px;">
      <span style="font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 18px; color: var(--text-primary);">Cove</span>
      <span style="font-size: 12px; color: var(--text-secondary); font-weight: 400;">Insights</span>
    </a>
    <a href="https://covecollect.com" style="font-size: 13px; font-weight: 500; color: var(--gold);">
      Back to Cove &rarr;
    </a>
  </nav>

  <slot />

  <!-- FOOTER -->
  <footer style="border-top: 1px solid var(--border); padding: 3rem 2rem; margin-top: 4rem; text-align: center;">
    <p style="font-size: 13px; color: var(--text-secondary);">
      &copy; {new Date().getFullYear()} Cove Collect. Built for collectors who think in decades.
    </p>
    <p style="font-size: 12px; color: var(--text-secondary); margin-top: 8px;">
      <a href="https://covecollect.com" style="color: var(--gold);">covecollect.com</a>
    </p>
  </footer>
</body>
</html>
