---
import Base from '../layouts/Base.astro';
import { getPublishedArticles, getArticleBySlug } from '../lib/supabase';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const articles = await getPublishedArticles();
  return articles.map(article => ({
    params: { slug: article.slug },
  }));
};

const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect('/');
}

// Get related articles (3 most recent, excluding current)
const allArticles = await getPublishedArticles();
const related = allArticles.filter(a => a.slug !== slug).slice(0, 3);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric'
  });
}

function readTime(body?: string): string {
  if (!body) return '3 min read';
  const words = body.replace(/<[^>]*>/g, '').split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}
---

<Base
  title={`${article.headline} — Cove Insights`}
  description={article.meta_description || article.summary}
  ogImage={article.og_image_url || article.hero_image_url || undefined}
  canonicalUrl={article.canonical_url || `https://insights.covecollect.com/${article.slug}`}
  noindex={article.noindex}
  publishedAt={article.published_at}
  articleType={true}
>
  <!-- HERO IMAGE — edge to edge -->
  {article.hero_image_url && (
    <div class="article-hero">
      <img
        src={article.hero_image_url}
        alt={article.headline}
        class="article-hero-img"
      />
    </div>
  )}

  <article class="article-container">

    <!-- ARTICLE HEADER -->
    <header class="article-header">
      <div class="article-header-meta-top">
        {article.primary_category && (
          <span class="article-category">{article.primary_category}</span>
        )}
        {article.primary_category && <span class="article-meta-sep">&middot;</span>}
        <span class="article-date">{formatDate(article.published_at)}</span>
      </div>
      <h1 class="article-headline">{article.headline}</h1>
      {article.subheadline && (
        <p class="article-subheadline">{article.subheadline}</p>
      )}
      <div class="article-meta-row">
        <span>{readTime(article.article_body)}</span>
        <span class="article-meta-sep">&middot;</span>
        <span>{formatDate(article.published_at)}</span>
      </div>
      <div class="article-header-rule"></div>
    </header>

    <!-- ARTICLE BODY -->
    <div
      class="article-body"
      set:html={article.article_body}
    />

    <!-- TAGS -->
    {article.tags && article.tags.length > 0 && (
      <div class="article-tags">
        <span class="tags-label">Topics</span>
        <div class="tags-list">
          {article.tags.map(tag => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      </div>
    )}

    <!-- CTA -->
    <div class="article-cta">
      <span class="cta-eyebrow">Cove Collect</span>
      <p class="cta-headline">Understand what your collection is worth.</p>
      <p class="cta-body">USPAP-compliant appraisals, insurance valuations, and continuous collection monitoring for serious collectors.</p>
      <a href="https://covecollect.com" class="cta-button">Explore Cove &rarr;</a>
    </div>

    <!-- RELATED ARTICLES -->
    {related.length > 0 && (
      <div class="related-section">
        <div class="related-heading">
          <span class="related-label">Continue Reading</span>
          <div class="related-rule"></div>
        </div>
        <div class="related-grid">
          {related.map(r => (
            <a href={`/${r.slug}`} class="related-card">
              {r.hero_image_url ? (
                <div class="related-image-wrapper">
                  <img src={r.hero_image_url} alt={r.headline} class="related-image" loading="lazy" />
                </div>
              ) : (
                <div class="related-text-card">
                  <h3 class="related-text-headline">{r.headline}</h3>
                </div>
              )}
              <div class="related-card-body">
                {r.primary_category && (
                  <span class="related-category">{r.primary_category}</span>
                )}
                <h3 class="related-headline">{r.headline}</h3>
                <p class="related-summary">{r.summary}</p>
                <span class="related-date">{formatDate(r.published_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </article>

  <script define:vars={{ articleTitle: article.headline, articleCategory: article.primary_category }}>
    window.gtag?.('event', 'blog_post_viewed', {
      article_title: articleTitle,
      article_category: articleCategory || 'uncategorized',
    });
  </script>
</Base>

<style>
  /* HERO */
  .article-hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .article-hero-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
  }

  /* CONTAINER */
  .article-container {
    max-width: var(--max-article);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* HEADER */
  .article-header {
    padding: 48px 0 40px;
  }

  .article-header-meta-top {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .article-category {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-date {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .article-meta-sep {
    color: var(--text-tertiary);
    font-size: 12px;
  }

  .article-headline {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin-top: 12px;
  }

  .article-subheadline {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-top: 12px;
  }

  .article-meta-row {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .article-header-rule {
    height: 1px;
    background: var(--border);
    margin-top: 32px;
  }

  /* ARTICLE BODY */
  .article-body {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.85;
    color: var(--text-secondary);
    font-weight: 300;
  }

  .article-body :global(> p:first-child) {
    font-size: 19px;
    line-height: 1.75;
    color: var(--text-primary);
    font-weight: 400;
  }

  .article-body :global(h2) {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text-primary);
    margin: 48px 0 16px;
    line-height: 1.2;
  }

  .article-body :global(h3) {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 32px 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .article-body :global(p) {
    margin-bottom: 24px;
  }

  .article-body :global(a) {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--gold-muted);
  }

  .article-body :global(blockquote) {
    border-left: 2px solid var(--gold);
    padding: 8px 0 8px 28px;
    margin: 40px 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    color: var(--text-primary);
    line-height: 1.5;
  }

  .article-body :global(img) {
    width: 100%;
    border-radius: 3px;
    margin: 40px 0;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 24px;
  }

  .article-body :global(li) {
    margin-bottom: 10px;
    color: var(--text-secondary);
  }

  .article-body :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }

  /* TAGS */
  .article-tags {
    border-top: 1px solid var(--border);
    padding-top: 32px;
    margin-top: 48px;
  }

  .tags-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 12px;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-secondary);
    border: 1px solid var(--border-strong);
    padding: 4px 12px;
    border-radius: 20px;
    transition: all 150ms;
  }

  .tag-pill:hover {
    color: var(--gold);
    border-color: var(--gold);
  }

  /* CTA */
  .article-cta {
    margin-top: 64px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    padding: 40px;
  }

  .cta-eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    color: var(--text-primary);
    margin-top: 8px;
  }

  .cta-body {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 15px;
    color: var(--text-secondary);
    margin-top: 8px;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    margin-top: 20px;
    background: var(--gold);
    color: #0C0C0A;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 6px;
    transition: filter 150ms;
  }

  .cta-button:hover {
    filter: brightness(1.1);
  }

  /* RELATED */
  .related-section {
    margin-top: 80px;
    padding-bottom: 80px;
  }

  .related-heading {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
  }

  .related-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .related-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .related-card {
    display: block;
    text-decoration: none;
  }

  .related-card:hover .related-image {
    transform: scale(1.04);
  }

  .related-card:hover .related-headline {
    color: var(--gold);
  }

  .related-image-wrapper {
    overflow: hidden;
    border-radius: 3px;
    aspect-ratio: 3 / 2;
  }

  .related-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .related-text-card {
    background: var(--bg-elevated);
    border-radius: 3px;
    aspect-ratio: 3 / 2;
    display: flex;
    align-items: center;
    padding: 24px;
  }

  .related-text-headline {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .related-card-body {
    padding-top: 12px;
  }

  .related-category {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 10px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .related-headline {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-top: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 150ms;
  }

  .related-summary {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-top: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-date {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 8px;
    display: block;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .article-container {
      padding: 0 1rem;
    }

    .article-hero-img {
      height: 280px;
    }

    .article-headline {
      font-size: 36px;
    }

    .article-body {
      font-size: 16px;
    }

    .article-body :global(> p:first-child) {
      font-size: 17px;
    }

    .article-body :global(h2) {
      font-size: 24px;
    }

    .article-cta {
      padding: 28px;
    }

    .related-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
