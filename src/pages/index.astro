---
import Base from '../layouts/Base.astro';
import { getPublishedArticles } from '../lib/supabase';

const articles = await getPublishedArticles();
const featured = articles[0];
const rest = articles.slice(1);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric'
  });
}

function readTime(body?: string): string {
  if (!body) return '3 min read';
  const words = body.replace(/<[^>]*>/g, '').split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}

const categories = ['All', 'Art', 'Cars', 'Watches', 'Wine'];
---

<Base
  title="Cove Insights — Market intelligence for serious collectors"
  description="Analysis, market intelligence, and collecting perspective from Cove — for collectors who think in decades."
>
  <main class="index-main">

    <!-- PAGE HEADER -->
    <header class="page-header">
      <div class="page-header-left">
        <span class="eyebrow">Expert Commentary</span>
        <h1 class="page-title">Insights</h1>
        <p class="page-subtitle">Markets, trends, and collecting strategy.</p>
      </div>
      <div class="page-header-right">
        <div class="category-pills">
          {categories.map((cat, i) => (
            <button class={`pill ${i === 0 ? 'pill-active' : ''}`}>{cat}</button>
          ))}
        </div>
      </div>
    </header>

    <div class="header-rule"></div>

    <!-- FEATURED HERO -->
    {featured && (
      <a href={`/${featured.slug}`} class="hero-card">
        <div class="hero-image-wrapper">
          {featured.hero_image_url ? (
            <img
              src={featured.hero_image_url}
              alt={featured.headline}
              class="hero-image"
            />
          ) : (
            <div class="hero-image-placeholder"></div>
          )}
        </div>
        <div class="hero-content">
          {featured.primary_category && (
            <span class="card-category">{featured.primary_category}</span>
          )}
          <h2 class="hero-headline">{featured.headline}</h2>
          <p class="hero-summary">{featured.summary}</p>
          <div class="hero-meta">
            <span>{formatDate(featured.published_at)}</span>
            <span class="meta-dot">&middot;</span>
            <span>{readTime(featured.article_body)}</span>
          </div>
          <span class="read-arrow">Read Article &rarr;</span>
        </div>
      </a>
    )}

    <!-- MORE INSIGHTS -->
    {rest.length > 0 && (
      <>
        <div class="section-heading">
          <span class="section-label">More Insights</span>
          <div class="section-rule"></div>
        </div>

        <div class="article-grid">
          {rest.map((article, i) => (
            <a
              href={`/${article.slug}`}
              class="article-card"
              style={`animation-delay: ${0.05 + i * 0.05}s`}
            >
              {article.hero_image_url ? (
                <div class="article-image-wrapper">
                  <img
                    src={article.hero_image_url}
                    alt={article.headline}
                    class="article-image"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="article-text-card">
                  <h2 class="article-text-card-headline">{article.headline}</h2>
                </div>
              )}
              <div class="article-card-body">
                {article.primary_category && (
                  <span class="card-category">{article.primary_category}</span>
                )}
                <h2 class="article-card-headline">{article.headline}</h2>
                <p class="article-card-summary">{article.summary}</p>
                <span class="article-card-date">{formatDate(article.published_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

  </main>
</Base>

<style>
  .index-main {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* PAGE HEADER */
  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 80px 0 60px;
  }

  .page-header-left {
    flex: 0 0 55%;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 400;
    line-height: 1.0;
    color: var(--text-primary);
    margin-top: 8px;
  }

  .page-subtitle {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 18px;
    color: var(--text-secondary);
    margin-top: 12px;
  }

  .page-header-right {
    flex: 0 0 45%;
    display: flex;
    justify-content: flex-end;
  }

  .category-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .pill {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border-strong);
    padding: 6px 16px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 150ms;
  }

  .pill:hover {
    color: var(--text-primary);
    border-color: var(--text-tertiary);
  }

  .pill-active {
    color: var(--gold);
    border-color: var(--gold);
    background: var(--gold-subtle);
  }

  .header-rule {
    height: 1px;
    background: var(--border);
    margin-bottom: 64px;
  }

  /* FEATURED HERO */
  .hero-card {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 0;
    margin-bottom: 80px;
    text-decoration: none;
  }

  .hero-card:hover .hero-image {
    transform: scale(1.02);
  }

  .hero-card:hover .read-arrow {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-image-wrapper {
    overflow: hidden;
    border-radius: 4px;
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .hero-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(12,12,10,0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .hero-image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--bg-elevated);
  }

  .hero-content {
    padding-left: 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-category {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-primary);
    margin-top: 8px;
  }

  .hero-summary {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-top: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-meta {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .meta-dot {
    color: var(--text-tertiary);
  }

  .read-arrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--gold);
    margin-top: 16px;
    transition: all 150ms;
  }

  /* SECTION HEADING */
  .section-heading {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
  }

  .section-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ARTICLE GRID */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 32px;
    padding-bottom: 80px;
  }

  .article-card {
    display: block;
    text-decoration: none;
    opacity: 0;
    animation: fadeUp 0.4s ease forwards;
  }

  .article-card:hover .article-image {
    transform: scale(1.04);
  }

  .article-card:hover .article-card-headline {
    color: var(--gold);
  }

  .article-image-wrapper {
    overflow: hidden;
    border-radius: 3px;
    aspect-ratio: 3 / 2;
  }

  .article-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .article-text-card {
    background: var(--bg-elevated);
    border-radius: 3px;
    aspect-ratio: 3 / 2;
    display: flex;
    align-items: center;
    padding: 32px;
  }

  .article-text-card-headline {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .article-card-body {
    padding-top: 16px;
  }

  .article-card-headline {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-top: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 150ms;
  }

  .article-card-summary {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card-date {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 12px;
    display: block;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-card {
      grid-template-columns: 1fr 1fr;
    }

    .hero-headline {
      font-size: 32px;
    }

    .hero-content {
      padding-left: 32px;
    }
  }

  @media (max-width: 640px) {
    .index-main {
      padding: 0 1rem;
    }

    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 48px 0 40px;
    }

    .page-header-left,
    .page-header-right {
      flex: none;
      width: 100%;
    }

    .page-header-right {
      justify-content: flex-start;
    }

    .category-pills {
      justify-content: flex-start;
    }

    .page-title {
      font-size: 48px;
    }

    .hero-card {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .hero-content {
      padding-left: 0;
    }

    .hero-headline {
      font-size: 28px;
    }

    .article-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .header-rule {
      margin-bottom: 40px;
    }
  }
</style>
